/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  color: #333;
  margin: 0;
  padding: 0;
}

/* 通用元素 */
view {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  background-color: transparent;
  border: none;
}

button:after {
  display: none;
}

input {
  margin: 0;
  padding: 0;
}

/* 文本溢出处理 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

/* 响应式 */
@media (max-width: 375px) {
  page {
    font-size: 14px;
  }
}
