page {
  background-color: #f7f8fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  color: #333;
}

view {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  background-color: transparent;
  border: none;
}

button::after {
  display: none;
}

input {
  margin: 0;
  padding: 0;
}



