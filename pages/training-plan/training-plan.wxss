.page-container {
  min-height: 100vh;
  background-color: #F0F8FF;
  padding: 16px;
  box-sizing: border-box;
}

.page-header {
  text-align: center;
  padding: 20px 0;
}

.header-emoji {
  font-size: 40px;
  margin-bottom: 8px;
}

.header-title {
  font-size: 22px;
  font-weight: 700;
  color: #E0F7FF;
  margin-bottom: 6px;
}

.header-subtitle {
  font-size: 13px;
  color: #999;
}

/* 天数切换 */
.day-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 16px;
  justify-content: center;
}

.day-tab {
  padding: 8px 14px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 600;
  color: #666;
  background-color: #ffffff;
  border: 2px solid #e0e0e0;
  transition: all 0.3s ease;
}

.day-tab.active {
  color: #ffffff;
  background: linear-gradient(135deg, #E0F7FF 0%, #D1ECFF 100%);
  border-color: #E0F7FF;
  box-shadow: 0 2px 8px rgba(255, 107, 157, 0.3);
}

/* 卡片 */
.card {
  background-color: #ffffff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.card-title {
  display: flex;
  align-items: center;
  font-size: 16px;
  font-weight: 700;
  color: #333;
  margin-bottom: 16px;
  gap: 8px;
}

.title-emoji {
  font-size: 18px;
}

/* 动作项 */
.exercise-item {
  margin-bottom: 16px;
  padding-bottom: 16px;
  border-bottom: 1px solid #f0f0f0;
}

.exercise-item:last-of-type {
  border-bottom: none;
  margin-bottom: 8px;
  padding-bottom: 8px;
}

.exercise-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}

.exercise-index {
  font-size: 13px;
  font-weight: 600;
  color: #E0F7FF;
}

.exercise-delete {
  font-size: 12px;
  color: #ff6b6b;
  padding: 4px 10px;
  border: 1px solid #ff6b6b;
  border-radius: 12px;
}

.exercise-inputs {
  display: flex;
  gap: 10px;
}

.exercise-name-group {
  flex: 2;
}

.exercise-sets-group {
  flex: 1;
}

.input-field {
  width: 100%;
  padding: 12px 14px;
  border: 2px solid #e0e0e0;
  border-radius: 10px;
  font-size: 14px;
  color: #333;
  background-color: #ffffff;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.input-field:focus {
  border-color: #E0F7FF;
  box-shadow: 0 0 0 3px rgba(255, 107, 157, 0.1);
}

/* 添加动作按钮 */
.add-exercise-btn {
  text-align: center;
  padding: 12px;
  color: #E0F7FF;
  font-size: 14px;
  font-weight: 600;
  border: 2px dashed #E0F7FF;
  border-radius: 10px;
  margin-top: 8px;
  transition: all 0.3s ease;
}

.add-exercise-btn:active {
  background-color: rgba(255, 107, 157, 0.06);
}

/* 保存按钮 */
.save-plan-btn {
  width: 100%;
  padding: 14px;
  background: linear-gradient(135deg, #E0F7FF 0%, #D1ECFF 100%);
  color: #ffffff;
  border-radius: 10px;
  font-size: 15px;
  font-weight: 700;
  border: none;
  box-shadow: 0 4px 12px rgba(255, 107, 157, 0.25);
  transition: all 0.3s ease;
}

.save-plan-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2px 6px rgba(255, 107, 157, 0.15);
}
