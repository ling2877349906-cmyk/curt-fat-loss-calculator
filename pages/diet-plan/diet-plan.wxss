.page-container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding: 16px;
  box-sizing: border-box;
}

.page-header {
  text-align: center;
  padding: 20px 0;
}

.header-emoji {
  font-size: 40px;
  margin-bottom: 8px;
}

.header-title {
  font-size: 22px;
  font-weight: 700;
  color: #99ccff;
  margin-bottom: 6px;
}

.header-subtitle {
  font-size: 13px;
  color: #999;
}

/* 天数切换 */
.day-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 16px;
  justify-content: center;
}

.day-tab {
  padding: 8px 14px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 600;
  color: #666;
  background-color: #f7f8fa;
  border: 2px solid #e0e0e0;
  transition: all 0.3s ease;
}

.day-tab.active {
  color: #ffffff;
  background: linear-gradient(135deg, #99ccff 0%, #99ccff 100%);
  border-color: #99ccff;
  box-shadow: 0 2px 8px rgba(153, 204, 255, 0.3);
}

/* 卡片 */
.card {
  background-color: #f7f8fa;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.card-title {
  display: flex;
  align-items: center;
  font-size: 16px;
  font-weight: 700;
  color: #333;
  margin-bottom: 16px;
  gap: 8px;
}

.title-emoji {
  font-size: 18px;
}

/* 食材项 */
.food-item {
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid #f0f0f0;
}

.food-item:last-of-type {
  border-bottom: none;
  margin-bottom: 8px;
  padding-bottom: 4px;
}

.food-inputs {
  display: flex;
  gap: 8px;
  align-items: center;
}

.food-name-group {
  flex: 2;
}

.food-grams-group {
  flex: 1;
}

.food-delete {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ff6b6b;
  font-size: 14px;
  border: 1px solid #ff6b6b;
  border-radius: 50%;
  flex-shrink: 0;
}

.input-field {
  width: 100%;
  padding: 10px 12px;
  border: 2px solid #e0e0e0;
  border-radius: 10px;
  font-size: 14px;
  color: #333;
  background-color: #f7f8fa;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.input-field:focus {
  border-color: #99ccff;
  box-shadow: 0 0 0 3px rgba(153, 204, 255, 0.1);
}

/* 单项营养素结果 */
.food-nutrition {
  margin-top: 6px;
  padding-left: 4px;
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.food-nutrition-item {
  font-size: 11px;
  color: #99ccff;
  font-weight: 500;
}

.food-not-found .food-nutrition-item {
  color: #999;
}

/* 添加食材按钮 */
.add-food-btn {
  text-align: center;
  padding: 10px;
  color: #99ccff;
  font-size: 13px;
  font-weight: 600;
  border: 2px dashed #99ccff;
  border-radius: 10px;
  margin-top: 8px;
  transition: all 0.3s ease;
}

.add-food-btn:active {
  background-color: rgba(153, 204, 255, 0.06);
}

/* 餐次汇总 */
.meal-summary {
  margin-top: 12px;
  padding: 10px 12px;
  background-color: rgba(153, 204, 255, 0.06);
  border-radius: 8px;
  border-left: 3px solid #99ccff;
}

.meal-summary-title {
  font-size: 12px;
  font-weight: 700;
  color: #99ccff;
  margin-bottom: 4px;
}

.meal-summary-data {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
}

.summary-item {
  font-size: 12px;
  color: #666;
  font-weight: 500;
}

/* 当日总汇总 */
.daily-summary-card {
  border: 2px solid #99ccff;
}

.daily-summary-grid {
  display: flex;
  justify-content: space-around;
}

.daily-summary-item {
  text-align: center;
}

.daily-summary-value {
  font-size: 20px;
  font-weight: 700;
  color: #99ccff;
  margin-bottom: 4px;
}

.daily-summary-label {
  font-size: 12px;
  color: #999;
  font-weight: 500;
}

/* 保存按钮 */
.save-plan-btn {
  width: 100%;
  padding: 14px;
  background: linear-gradient(135deg, #99ccff 0%, #99ccff 100%);
  color: #ffffff;
  border-radius: 10px;
  font-size: 15px;
  font-weight: 700;
  border: none;
  box-shadow: 0 4px 12px rgba(153, 204, 255, 0.25);
  transition: all 0.3s ease;
}

.save-plan-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2px 6px rgba(153, 204, 255, 0.15);
}
