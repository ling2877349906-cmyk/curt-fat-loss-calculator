<view class="page-container">
  <!-- Tab导航 -->
  <view class="tab-nav">
    <view wx:for="{{tabs}}" wx:key="index" class="tab-item {{activeTab === index ? 'active' : ''}}" bindtap="switchTab" data-index="{{index}}">
      {{item}}
    </view>
  </view>

  <!-- 热量计算页 -->
  <view class="tab-content {{activeTab === 0 ? 'active' : ''}}">
    <!-- 页面标题 -->
    <view class="page-header">
      <view class="header-emoji">💪</view>
      <view class="header-title">热量计算器</view>
      <view class="header-subtitle">让我们计算你的每日热量需求</view>
    </view>

    <!-- 基础热量区 -->
    <view class="card">
      <view class="card-title">
        <view class="title-emoji">📊</view>
        <view>基础热量（BMR）</view>
      </view>
      
      <view class="input-group">
        <view class="input-label">性别</view>
        <view class="gender-buttons">
          <button class="gender-btn {{calorieData.gender === 'male' ? 'active' : ''}}" bindtap="onGenderChange" data-gender="male">👨 男性</button>
          <button class="gender-btn {{calorieData.gender === 'female' ? 'active' : ''}}" bindtap="onGenderChange" data-gender="female">👩 女性</button>
        </view>
      </view>

      <view class="input-group">
        <view class="input-label">年龄</view>
        <input class="input-field" type="text" inputmode="numeric" value="{{calorieData.age}}" bindinput="onAgeInput" placeholder="输入年龄" placeholder-style="color: #ccc;" />
      </view>

      <view class="input-group">
        <view class="input-label">身高 (cm)</view>
        <input class="input-field" type="text" inputmode="numeric" value="{{calorieData.height}}" bindinput="onHeightInput" placeholder="输入身高" placeholder-style="color: #ccc;" />
      </view>

      <view class="input-group">
        <view class="input-label">体重 (kg)</view>
        <input class="input-field" type="text" inputmode="numeric" value="{{calorieData.weight}}" bindinput="onWeightInput" placeholder="输入体重" placeholder-style="color: #ccc;" />
      </view>

      <view class="result-display" wx:if="{{calorieData.bmr}}">
        <view class="result-label">基础代谢率</view>
        <view class="result-value">{{calorieData.bmr}} <text class="result-unit">千卡</text></view>
      </view>
      <view class="result-placeholder" wx:else>
        <view class="placeholder-text">填写上方信息后显示</view>
      </view>
    </view>

    <!-- 训练热量区 -->
    <view class="card">
      <view class="card-title">
        <view class="title-emoji">🔥</view>
        <view>训练热量</view>
      </view>

      <view class="input-group">
        <view class="input-label">每日有氧训练时间 (分钟)</view>
        <input class="input-field" type="text" inputmode="numeric" value="{{calorieData.cardioMinutes}}" bindinput="onCardioMinutesInput" placeholder="如快走、慢跑、骑行等，默认0" placeholder-style="color: #ccc;" />
      </view>

      <view class="input-group">
        <view class="input-label">每日无氧训练时间 (分钟)</view>
        <input class="input-field" type="text" inputmode="numeric" value="{{calorieData.strengthMinutes}}" bindinput="onStrengthMinutesInput" placeholder="如力量训练、器械等，默认0" placeholder-style="color: #ccc;" />
      </view>

      <!-- 分项热量结果 -->
      <view class="train-detail-results" wx:if="{{calorieData.cardioCalories > 0 || calorieData.strengthCalories > 0}}">
        <view class="train-detail-item">
          <view class="train-detail-label">🏃 有氧消耗热量</view>
          <view class="train-detail-value">{{calorieData.cardioCalories}} 千卡</view>
        </view>
        <view class="train-detail-item">
          <view class="train-detail-label">🏋️ 无氧消耗热量</view>
          <view class="train-detail-value">{{calorieData.strengthCalories}} 千卡</view>
        </view>
      </view>

      <view class="result-display" wx:if="{{calorieData.trainCalories}}">
        <view class="result-label">训练消耗总热量</view>
        <view class="result-value">{{calorieData.trainCalories}} <text class="result-unit">千卡</text></view>
      </view>
      <view class="result-placeholder" wx:else>
        <view class="placeholder-text">填写上方信息后显示</view>
      </view>
    </view>

    <!-- 每日总热量 -->
    <view class="card highlight-card" wx:if="{{calorieData.tdee}}">
      <view class="highlight-label">🎯 每日可消耗总热量</view>
      <view class="highlight-value">{{calorieData.tdee}} <text class="highlight-unit">千卡</text></view>
    </view>

    <!-- 营养素分配区 -->
    <view class="card">
      <view class="card-title">
        <view class="title-emoji">🥗</view>
        <view>营养素分配</view>
      </view>

      <view class="input-group">
        <view class="input-label">选择模式</view>
        <view class="nutrition-buttons">
          <button class="nutrition-btn {{calorieData.nutritionMode === 'bulk' ? 'active' : ''}}" bindtap="onNutritionModeChange" data-mode="bulk">
            <view class="nutrition-emoji">💪</view>
            增肌模式
          </button>
          <button class="nutrition-btn {{calorieData.nutritionMode === 'cut' ? 'active' : ''}}" bindtap="onNutritionModeChange" data-mode="cut">
            <view class="nutrition-emoji">⚖️</view>
            减脂模式
          </button>
          <button class="nutrition-btn {{calorieData.nutritionMode === 'custom' ? 'active' : ''}}" bindtap="onNutritionModeChange" data-mode="custom">
            <view class="nutrition-emoji">⚙️</view>
            自定义
          </button>
        </view>
      </view>

      <!-- 自定义模式输入 -->
      <view wx:if="{{calorieData.nutritionMode === 'custom'}}" class="custom-nutrition">
        <view class="input-hint">输入营养素百分比（总和必须为100%）</view>
        <view class="input-group">
          <view class="input-label">碳水百分比 (%)</view>
          <input class="input-field" type="text" inputmode="numeric" value="{{calorieData.customNutrition.carbs}}" bindinput="onCustomCarbsInput" placeholder="输入碳水百分比" placeholder-style="color: #ccc;" />
        </view>
        <view class="input-group">
          <view class="input-label">蛋白质百分比 (%)</view>
          <input class="input-field" type="text" inputmode="numeric" value="{{calorieData.customNutrition.protein}}" bindinput="onCustomProteinInput" placeholder="输入蛋白质百分比" placeholder-style="color: #ccc;" />
        </view>
        <view class="input-group">
          <view class="input-label">脂肪热量 (千卡)</view>
          <input class="input-field" type="text" inputmode="numeric" value="{{calorieData.customNutrition.fat}}" bindinput="onCustomFatInput" placeholder="输入脂肪百分比" placeholder-style="color: #ccc;" />
        </view>
      </view>

      <!-- 营养素结果 -->
      <view class="nutrition-results" wx:if="{{calorieData.nutritionMode}}">
        <!-- 减脂模式前3天低碳日标签 -->
        <view wx:if="{{calorieData.nutritionMode === 'cut'}}" class="day4-title">前3天（低碳日）</view>
        <view class="nutrition-item">
          <view class="nutrition-label">
            <view class="nutrition-emoji">🌾</view>
            碳水
          </view>
          <view class="nutrition-value">{{calorieData.nutrition.carbsGrams}} g / {{calorieData.nutrition.carbs}} 千卡</view>
        </view>
        <view class="nutrition-item">
          <view class="nutrition-label">
            <view class="nutrition-emoji">🥚</view>
            蛋白质
          </view>
          <view class="nutrition-value">{{calorieData.nutrition.proteinGrams}} g / {{calorieData.nutrition.protein}} 千卡</view>
        </view>
        <view class="nutrition-item">
          <view class="nutrition-label">
            <view class="nutrition-emoji">🧈</view>
            脂肪
          </view>
          <view class="nutrition-value">{{calorieData.nutrition.fatGrams}} g / {{calorieData.nutrition.fat}} 千卡</view>
        </view>

        <!-- 减脂模式第4天 -->
        <view wx:if="{{calorieData.nutritionMode === 'cut' && calorieData.nutrition.carbsDay4}}" class="day4-section">
          <view class="day4-title">第4天（高碳日）</view>
          <view class="nutrition-item">
            <view class="nutrition-label">
              <view class="nutrition-emoji">🌾</view>
              碳水
            </view>
            <view class="nutrition-value">{{calorieData.nutrition.carbsGramsDay4}} g / {{calorieData.nutrition.carbsDay4}} 千卡</view>
          </view>
          <view class="nutrition-item">
            <view class="nutrition-label">
              <view class="nutrition-emoji">🥚</view>
              蛋白质
            </view>
            <view class="nutrition-value">{{calorieData.nutrition.proteinGramsDay4}} g / {{calorieData.nutrition.proteinDay4}} 千卡</view>
          </view>
          <view class="nutrition-item">
            <view class="nutrition-label">
              <view class="nutrition-emoji">🧈</view>
              脂肪
            </view>
            <view class="nutrition-value">{{calorieData.nutrition.fatGramsDay4}} g / {{calorieData.nutrition.fatDay4}} 千卡</view>
          </view>
        </view>
      </view>
      <view class="result-placeholder" wx:else>
        <view class="placeholder-text">选择一个模式后显示营养数据</view>
      </view>
    </view>

    <!-- 减脂与增肌小知识 -->
    <view class="card knowledge-card">
      <view class="card-title">
        <view class="title-emoji">💡</view>
        <view>减脂与增肌小知识</view>
      </view>
      <view class="knowledge-content">
        <view class="knowledge-text">{{currentKnowledge}}</view>
      </view>
    </view>

    <view style="height: 20px;"></view>
  </view>

  <!-- 减脂预测页 -->
  <view class="tab-content {{activeTab === 1 ? 'active' : ''}}">
    <!-- 页面标题 -->
    <view class="page-header">
      <view class="header-emoji">📉</view>
      <view class="header-title">减脂预测</view>
      <view class="header-subtitle">规划你的减脂目标</view>
    </view>

    <view class="card">
      <view class="card-title">
        <view class="title-emoji">⚖️</view>
        <view>减脂参数</view>
      </view>

      <view class="input-group">
        <view class="input-label">初始体重 (kg)</view>
        <input class="input-field" type="text" inputmode="numeric" value="{{predictionData.initialWeight}}" bindinput="onInitialWeightInput" placeholder="输入初始体重" placeholder-style="color: #ccc;" />
      </view>

      <view class="input-group">
        <view class="input-label">目标体重 (kg)</view>
        <input class="input-field" type="text" inputmode="numeric" value="{{predictionData.targetWeight}}" bindinput="onTargetWeightInput" placeholder="输入目标体重" placeholder-style="color: #ccc;" />
      </view>

      <view class="input-group">
        <view class="input-label">每月减重比例</view>
        <view class="percent-control">
          <button class="percent-btn" bindtap="decreasePercent">−</button>
          <view class="percent-display">{{predictionData.monthlyLossPercent || '—'}}%</view>
          <button class="percent-btn" bindtap="increasePercent">+</button>
        </view>
        <view class="percent-hint">范围: 1% - 5%</view>
      </view>
    </view>

    <!-- 预测结果 -->
    <view class="card" wx:if="{{predictionData.totalLoss}}">
      <view class="card-title">
        <view class="title-emoji">📊</view>
        <view>预测结果</view>
      </view>

      <view class="result-item">
        <view class="result-label">一共需要减重</view>
        <view class="result-value">{{predictionData.totalLoss}} kg</view>
      </view>

      <view class="result-item">
        <view class="result-label">预计时间</view>
        <view class="result-value">{{predictionData.predictMonths}} 月 ({{predictionData.predictWeeks}} 周 {{predictionData.predictDays}} 天)</view>
      </view>

      <view class="result-item">
        <view class="result-label">每月需要减重</view>
        <view class="result-value">{{predictionData.monthlyLoss}} kg</view>
      </view>

      <view class="result-item">
        <view class="result-label">每7天需要减重</view>
        <view class="result-value">{{predictionData.weeklyLoss}} kg</view>
      </view>

      <button class="save-btn" bindtap="savePredictionTarget">💾 保存目标</button>
    </view>

    <view class="card" wx:else>
      <view class="result-placeholder">
        <view class="placeholder-text">填写上方信息后显示预测结果</view>
      </view>
    </view>

    <!-- 减脂目标（从个人页迁移过来） -->
    <view class="card">
      <view class="card-title">
        <view class="title-emoji">🎯</view>
        <view>减脂目标</view>
      </view>

      <view class="data-item" wx:if="{{predictionData.initialWeight}}">
        <view class="data-label">当前体重</view>
        <view class="data-value">{{predictionData.initialWeight}} kg</view>
      </view>

      <view class="data-item" wx:if="{{predictionData.targetWeight}}">
        <view class="data-label">目标体重</view>
        <view class="data-value">{{predictionData.targetWeight}} kg</view>
      </view>

      <!-- 7日体重记录 -->
      <view class="weight-records" wx:if="{{weightRecords.length > 0}}">
        <view class="records-title">📊 近7日体重记录</view>
        <view class="records-list">
          <view class="record-item" wx:for="{{weightRecords}}" wx:key="timestamp">
            <view class="record-date">{{item.dateStr}}</view>
            <view class="record-weight">{{item.weight}} kg</view>
          </view>
        </view>
      </view>

      <view class="weight-records-empty" wx:if="{{weightRecords.length === 0}}">
        <view class="empty-text">暂无体重记录，点击下方按钮开始记录</view>
      </view>

      <button class="record-btn" bindtap="goToWeightRecord">📝 记录体重</button>
    </view>

    <view style="height: 20px;"></view>
  </view>

  <!-- 个人页 -->
  <view class="tab-content {{activeTab === 2 ? 'active' : ''}}">
    <!-- 页面标题 -->
    <view class="page-header">
      <view class="header-emoji">👤</view>
      <view class="header-title">个人信息</view>
      <view class="header-subtitle">查看你的身体数据</view>
    </view>

    <view class="card">
      <view class="card-title">
        <view class="title-emoji">📋</view>
        <view>身体数据</view>
      </view>

      <view class="data-item" wx:if="{{calorieData.age}}">
        <view class="data-label">年龄</view>
        <view class="data-value">{{calorieData.age}} 岁</view>
      </view>

      <view class="data-item" wx:if="{{calorieData.height}}">
        <view class="data-label">身高</view>
        <view class="data-value">{{calorieData.height}} cm</view>
      </view>

      <view class="data-item" wx:if="{{calorieData.weight}}">
        <view class="data-label">体重</view>
        <view class="data-value">{{calorieData.weight}} kg</view>
      </view>

      <view class="data-item" wx:if="{{calorieData.gender}}">
        <view class="data-label">性别</view>
        <view class="data-value">{{calorieData.gender === 'male' ? '👨 男性' : '👩 女性'}}</view>
      </view>

      <view class="data-item" wx:if="{{calorieData.tdee}}">
        <view class="data-label">每日热量需求</view>
        <view class="data-value">{{calorieData.tdee}} 千卡</view>
      </view>
    </view>

    <view class="card">
      <view class="card-title">
        <view class="title-emoji">📏</view>
        <view>BMI指数</view>
      </view>

      <view class="bmi-display" wx:if="{{profileData.bmi}}">
        <view class="bmi-value">{{profileData.bmi}}</view>
        <view class="bmi-status">{{profileData.bmiStatus}}</view>
      </view>

      <view class="bmi-scale">
        <view class="scale-item">
          <view class="scale-label">偏瘦</view>
          <view class="scale-range">&lt;18.5</view>
        </view>
        <view class="scale-item">
          <view class="scale-label">正常</view>
          <view class="scale-range">18.5-24</view>
        </view>
        <view class="scale-item">
          <view class="scale-label">偏胖</view>
          <view class="scale-range">&gt;24</view>
        </view>
      </view>
    </view>

    <!-- 训练计划 -->
    <view class="card">
      <view class="card-title card-title-with-btn">
        <view class="card-title-left">
          <view class="title-emoji">🏋️</view>
          <view>训练计划</view>
        </view>
        <view class="card-title-btn" bindtap="goToTrainingPlan">点击填写</view>
      </view>
    </view>

    <!-- 饮食计划 -->
    <view class="card">
      <view class="card-title card-title-with-btn">
        <view class="card-title-left">
          <view class="title-emoji">🍚</view>
          <view>饮食计划</view>
        </view>
        <view class="card-title-btn" bindtap="goToDietPlan">开始计划</view>
      </view>
    </view>

    <!-- 记录打卡 -->
    <view class="card">
      <view class="card-title">
        <view class="title-emoji">📅</view>
        <view>记录打卡</view>
      </view>

      <!-- 日历导航 -->
      <view class="calendar-nav">
        <view class="calendar-nav-btn" bindtap="prevMonth">❮</view>
        <view class="calendar-nav-title">{{calendarYear}}年{{calendarMonth}}月</view>
        <view class="calendar-nav-btn" bindtap="nextMonth">❯</view>
      </view>

      <!-- 星期头 -->
      <view class="calendar-weekdays">
        <view class="calendar-weekday">日</view>
        <view class="calendar-weekday">一</view>
        <view class="calendar-weekday">二</view>
        <view class="calendar-weekday">三</view>
        <view class="calendar-weekday">四</view>
        <view class="calendar-weekday">五</view>
        <view class="calendar-weekday">六</view>
      </view>

      <!-- 日期格子 -->
      <view class="calendar-days">
        <view wx:for="{{calendarDays}}" wx:key="index"
          class="calendar-day {{item.isCurrentMonth ? '' : 'other-month'}} {{item.isToday ? 'today' : ''}} {{item.hasCheckin ? 'checked-in' : ''}}"
          bindtap="onDayTap" data-date="{{item.dateStr}}" data-is-current="{{item.isCurrentMonth}}">
          <view class="day-number">{{item.day}}</view>
          <view class="day-dot" wx:if="{{item.hasCheckin}}"></view>
        </view>
      </view>
    </view>

    <!-- 打卡弹窗 -->
    <view class="checkin-modal" wx:if="{{showCheckinModal}}">
      <view class="checkin-mask" bindtap="closeCheckinModal"></view>
      <view class="checkin-dialog">
        <view class="checkin-dialog-header">
          <view class="checkin-dialog-title">📝 {{checkinDate}} 打卡记录</view>
          <view class="checkin-dialog-close" bindtap="closeCheckinModal">✕</view>
        </view>

        <view class="checkin-form">
          <view class="checkin-input-group">
            <view class="checkin-input-label">💧 喝水次数</view>
            <input class="checkin-input-field" type="number" value="{{checkinData.waterCount}}" bindinput="onWaterInput" placeholder="输入喝水次数" placeholder-style="color: #ccc;" />
          </view>

          <view class="checkin-input-group">
            <view class="checkin-input-label">🏋️ 训练时长（分钟）</view>
            <input class="checkin-input-field" type="number" value="{{checkinData.trainMinutes}}" bindinput="onTrainMinutesInput" placeholder="输入训练分钟数" placeholder-style="color: #ccc;" />
          </view>

          <view class="checkin-input-group">
            <view class="checkin-input-label">🍚 饮食记录</view>
            <textarea class="checkin-textarea" value="{{checkinData.dietRecord}}" bindinput="onDietInput" placeholder="记录今日饮食内容..." placeholder-style="color: #ccc;" maxlength="500"></textarea>
          </view>
        </view>

        <button class="checkin-save-btn" bindtap="saveCheckin">✅ 保存打卡</button>
      </view>
    </view>

    <view class="card">
      <view class="card-title">
        <view class="title-emoji">❓</view>
        <view>常见问题</view>
      </view>

      <view class="faq-item">
        <view class="faq-question">小程序来自哪里？</view>
        <view class="faq-answer">本小程序由 Curt 团队开发，致力于为用户提供科学的减脂计算工具。</view>
      </view>

      <view class="faq-item">
        <view class="faq-question">会有广告吗？</view>
        <view class="faq-answer">暂无广告，我们致力于提供纯净的用户体验。</view>
      </view>

      <view class="faq-item">
        <view class="faq-question">数据会被保存吗？</view>
        <view class="faq-answer">所有数据仅保存在您的手机本地，不会上传到服务器。</view>
      </view>
    </view>

    <view style="height: 20px;"></view>
  </view>
</view>
