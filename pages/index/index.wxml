<view class="page-container">
  <!-- Tab导航 -->
  <view class="tab-nav">
    <view wx:for="{{tabs}}" wx:key="index" class="tab-item {{activeTab === index ? 'active' : ''}}" bindtap="switchTab" data-index="{{index}}">
      {{item}}
    </view>
  </view>

  <!-- 热量计算页 -->
  <view class="tab-content {{activeTab === 0 ? 'active' : ''}}">
    <!-- 基础热量区 -->
    <view class="card">
      <view class="card-title">基础热量（BMR）</view>
      
      <view class="input-group">
        <view class="input-label">性别</view>
        <view class="gender-buttons">
          <button class="gender-btn {{calorieData.gender === 'male' ? 'active' : ''}}" bindtap="onGenderChange" data-gender="male">男性</button>
          <button class="gender-btn {{calorieData.gender === 'female' ? 'active' : ''}}" bindtap="onGenderChange" data-gender="female">女性</button>
        </view>
      </view>

      <view class="input-group">
        <view class="input-label">年龄</view>
        <input class="input-field" type="number" value="{{calorieData.age}}" bindinput="onAgeInput" placeholder="输入年龄" />
      </view>

      <view class="input-group">
        <view class="input-label">身高 (cm)</view>
        <input class="input-field" type="number" value="{{calorieData.height}}" bindinput="onHeightInput" placeholder="输入身高" />
      </view>

      <view class="input-group">
        <view class="input-label">体重 (kg)</view>
        <input class="input-field" type="number" value="{{calorieData.weight}}" bindinput="onWeightInput" placeholder="输入体重" />
      </view>

      <view class="result-display">
        <view class="result-label">基础代谢率</view>
        <view class="result-value">{{calorieData.bmr}} <text class="result-unit">千卡</text></view>
      </view>
    </view>

    <!-- 训练热量区 -->
    <view class="card">
      <view class="card-title">训练热量</view>

      <view class="input-group">
        <view class="input-label">每日训练时间 (分钟)</view>
        <input class="input-field" type="number" value="{{calorieData.trainTime}}" bindinput="onTrainTimeInput" placeholder="输入训练时间" />
      </view>

      <view class="input-group">
        <view class="input-label">训练强度</view>
        <view class="intensity-buttons">
          <button class="intensity-btn {{calorieData.trainIntensity === 5 ? 'active' : ''}}" bindtap="onIntensityChange" data-intensity="5">新手<br/>(系数5)</button>
          <button class="intensity-btn {{calorieData.trainIntensity === 8 ? 'active' : ''}}" bindtap="onIntensityChange" data-intensity="8">爱好者<br/>(系数8)</button>
          <button class="intensity-btn {{calorieData.trainIntensity === 10 ? 'active' : ''}}" bindtap="onIntensityChange" data-intensity="10">老手<br/>(系数10)</button>
        </view>
      </view>

      <view class="result-display">
        <view class="result-label">训练消耗热量</view>
        <view class="result-value">{{calorieData.trainCalories}} <text class="result-unit">千卡</text></view>
      </view>
    </view>

    <!-- 每日总热量 -->
    <view class="card highlight-card">
      <view class="highlight-label">每日可消耗总热量</view>
      <view class="highlight-value">{{calorieData.tdee}} <text class="highlight-unit">千卡</text></view>
    </view>

    <!-- 营养素分配区 -->
    <view class="card">
      <view class="card-title">营养素分配</view>

      <view class="input-group">
        <view class="input-label">选择比例</view>
        <view class="nutrition-buttons">
          <button class="nutrition-btn {{calorieData.nutritionMode === '532' ? 'active' : ''}}" bindtap="onNutritionModeChange" data-mode="532">532比例</button>
          <button class="nutrition-btn {{calorieData.nutritionMode === '442' ? 'active' : ''}}" bindtap="onNutritionModeChange" data-mode="442">442比例</button>
          <button class="nutrition-btn {{calorieData.nutritionMode === 'custom' ? 'active' : ''}}" bindtap="onNutritionModeChange" data-mode="custom">自定义</button>
        </view>
      </view>

      <!-- 自定义比例输入 -->
      <view wx:if="{{calorieData.nutritionMode === 'custom'}}" class="custom-nutrition">
        <view class="input-group">
          <view class="input-label">碳水 (%)</view>
          <input class="input-field" type="number" value="{{calorieData.customNutrition.carbs}}" bindinput="onCustomCarbsInput" placeholder="输入百分比" />
        </view>
        <view class="input-group">
          <view class="input-label">蛋白质 (%)</view>
          <input class="input-field" type="number" value="{{calorieData.customNutrition.protein}}" bindinput="onCustomProteinInput" placeholder="输入百分比" />
        </view>
        <view class="input-group">
          <view class="input-label">脂肪 (%)</view>
          <input class="input-field" type="number" value="{{calorieData.customNutrition.fat}}" bindinput="onCustomFatInput" placeholder="输入百分比" />
        </view>
      </view>

      <!-- 营养素结果 -->
      <view class="nutrition-results">
        <view class="nutrition-item">
          <view class="nutrition-label">碳水</view>
          <view class="nutrition-value">{{calorieData.nutrition.carbs}} 千卡 / {{calorieData.nutrition.carbsGrams}} 克</view>
        </view>
        <view class="nutrition-item">
          <view class="nutrition-label">蛋白质</view>
          <view class="nutrition-value">{{calorieData.nutrition.protein}} 千卡 / {{calorieData.nutrition.proteinGrams}} 克</view>
        </view>
        <view class="nutrition-item">
          <view class="nutrition-label">脂肪</view>
          <view class="nutrition-value">{{calorieData.nutrition.fat}} 千卡 / {{calorieData.nutrition.fatGrams}} 克</view>
        </view>
      </view>
    </view>

    <!-- 食谱推荐 -->
    <view class="card">
      <view class="card-title">食谱推荐</view>
      <view class="recipe-buttons">
        <button class="recipe-btn">薄荷健康</button>
        <button class="recipe-btn">薄荷</button>
        <button class="recipe-btn">训记</button>
      </view>
    </view>

    <view style="height: 20px;"></view>
  </view>

  <!-- 减脂预测页 -->
  <view class="tab-content {{activeTab === 1 ? 'active' : ''}}">
    <view class="card">
      <view class="card-title">减脂预测</view>

      <view class="input-group">
        <view class="input-label">初始体重 (kg)</view>
        <input class="input-field" type="number" value="{{predictionData.initialWeight}}" bindinput="onInitialWeightInput" placeholder="输入初始体重" />
      </view>

      <view class="input-group">
        <view class="input-label">目标体重 (kg)</view>
        <input class="input-field" type="number" value="{{predictionData.targetWeight}}" bindinput="onTargetWeightInput" placeholder="输入目标体重" />
      </view>

      <view class="input-group">
        <view class="input-label">每月减重比例</view>
        <view class="percent-control">
          <button class="percent-btn" bindtap="decreasePercent">−</button>
          <view class="percent-display">{{predictionData.monthlyLossPercent}}%</view>
          <button class="percent-btn" bindtap="increasePercent">+</button>
        </view>
        <view class="percent-hint">范围: 1% - 5%</view>
      </view>
    </view>

    <!-- 预测结果 -->
    <view class="card">
      <view class="card-title">预测结果</view>

      <view class="result-item">
        <view class="result-label">一共需要减重</view>
        <view class="result-value">{{predictionData.totalLoss}} kg</view>
      </view>

      <view class="result-item">
        <view class="result-label">预计时间</view>
        <view class="result-value">{{predictionData.predictMonths}} 月 ({{predictionData.predictWeeks}} 周 {{predictionData.predictDays}} 天)</view>
      </view>

      <view class="result-item">
        <view class="result-label">每月需要减重</view>
        <view class="result-value">{{predictionData.monthlyLoss}} kg</view>
      </view>

      <view class="result-item">
        <view class="result-label">每7天需要减重</view>
        <view class="result-value">{{predictionData.weeklyLoss}} kg</view>
      </view>

      <button class="save-btn" bindtap="savePredictionTarget">保存目标</button>
    </view>

    <view style="height: 20px;"></view>
  </view>

  <!-- 个人页 -->
  <view class="tab-content {{activeTab === 2 ? 'active' : ''}}">
    <view class="card">
      <view class="card-title">身体数据</view>

      <view class="data-item">
        <view class="data-label">年龄</view>
        <view class="data-value">{{calorieData.age}} 岁</view>
      </view>

      <view class="data-item">
        <view class="data-label">身高</view>
        <view class="data-value">{{calorieData.height}} cm</view>
      </view>

      <view class="data-item">
        <view class="data-label">体重</view>
        <view class="data-value">{{calorieData.weight}} kg</view>
      </view>

      <view class="data-item">
        <view class="data-label">性别</view>
        <view class="data-value">{{calorieData.gender === 'male' ? '男性' : '女性'}}</view>
      </view>
    </view>

    <view class="card">
      <view class="card-title">BMI指数</view>

      <view class="bmi-display">
        <view class="bmi-value">{{profileData.bmi}}</view>
        <view class="bmi-status">{{profileData.bmiStatus}}</view>
      </view>

      <view class="bmi-scale">
        <view class="scale-item">
          <view class="scale-label">偏瘦</view>
          <view class="scale-range">&lt;18.5</view>
        </view>
        <view class="scale-item">
          <view class="scale-label">正常</view>
          <view class="scale-range">18.5-24</view>
        </view>
        <view class="scale-item">
          <view class="scale-label">偏胖</view>
          <view class="scale-range">&gt;24</view>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="card-title">减脂目标</view>

      <view class="data-item">
        <view class="data-label">当前体重</view>
        <view class="data-value">{{profileData.currentWeight}} kg</view>
      </view>

      <view class="data-item">
        <view class="data-label">目标体重</view>
        <view class="data-value">{{profileData.currentWeight - predictionData.totalLoss}} kg</view>
      </view>

      <button class="record-btn">记录体重</button>
    </view>

    <view class="card">
      <view class="card-title">常见问题</view>

      <view class="faq-item">
        <view class="faq-question">小程序来自哪里？</view>
        <view class="faq-answer">本小程序由 Curt 团队开发，致力于为用户提供科学的减脂计算工具。</view>
      </view>

      <view class="faq-item">
        <view class="faq-question">会有广告吗？</view>
        <view class="faq-answer">暂无广告，我们致力于提供纯净的用户体验。</view>
      </view>

      <view class="faq-item">
        <view class="faq-question">数据会被保存吗？</view>
        <view class="faq-answer">所有数据仅保存在您的手机本地，不会上传到服务器。</view>
      </view>
    </view>

    <view style="height: 20px;"></view>
  </view>
</view>
