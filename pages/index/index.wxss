.page-container {
  background: linear-gradient(135deg, #f8f9fa 0%, #f0f5ff 100%);
  min-height: 100vh;
  padding-bottom: 20px;
}

/* Tab导航 */
.tab-nav {
  display: flex;
  background-color: #ffffff;
  border-bottom: 2px solid #e0e0e0;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 14px 0;
  font-size: 15px;
  font-weight: 600;
  color: #999;
  border-bottom: 4px solid transparent;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #2DC78F;
  border-bottom-color: #2DC78F;
}

/* Tab内容 */
.tab-content {
  display: none;
  animation: fadeIn 0.3s ease;
}

.tab-content.active {
  display: block;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 页面标题 */
.page-header {
  text-align: center;
  padding: 24px 16px 16px;
}

.header-emoji {
  font-size: 48px;
  display: block;
  margin-bottom: 8px;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10px);
  }
}

.header-title {
  font-size: 24px;
  font-weight: 700;
  color: #2DC78F;
  margin-bottom: 4px;
}

.header-subtitle {
  font-size: 13px;
  color: #999;
}

/* 卡片 */
.card {
  background-color: #ffffff;
  margin: 12px;
  border-radius: 16px;
  padding: 18px;
  box-shadow: 0 4px 12px rgba(45, 199, 143, 0.08);
  border: 1px solid rgba(45, 199, 143, 0.1);
}

.card-title {
  display: flex;
  align-items: center;
  font-size: 16px;
  font-weight: 700;
  color: #333;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 2px solid #f0f0f0;
}

.title-emoji {
  font-size: 20px;
  margin-right: 8px;
  display: inline-block;
}

/* 输入组 */
.input-hint {
  font-size: 12px;
  color: #2DC78F;
  margin-bottom: 12px;
  padding: 8px 12px;
  background-color: #f0f9f6;
  border-radius: 6px;
  border-left: 3px solid #2DC78F;
}

.input-group {
  margin-bottom: 14px;
}

.input-label {
  font-size: 13px;
  color: #666;
  margin-bottom: 10px;
  display: block;
  font-weight: 600;
}

.input-field {
  width: 100%;
  padding: 12px 14px;
  border: 2px solid #e0e0e0;
  border-radius: 10px;
  font-size: 15px;
  color: #333;
  background-color: #ffffff;
  box-sizing: border-box;
  transition: all 0.3s ease;
  -webkit-appearance: none;
  -webkit-tap-highlight-color: transparent;
  cursor: text;
}

input.input-field {
  color: #333;
  background-color: #ffffff;
}

.input-field:focus {
  border-color: #2DC78F;
  box-shadow: 0 0 0 3px rgba(45, 199, 143, 0.1);
  outline: none;
}

/* 性别按钮 */
.gender-buttons {
  display: flex;
  gap: 12px;
}

.gender-btn {
  flex: 1;
  padding: 12px;
  border: 2px solid #e0e0e0;
  border-radius: 10px;
  font-size: 14px;
  color: #333;
  background-color: #ffffff;
  transition: all 0.3s ease;
  font-weight: 600;
}

.gender-btn.active {
  border-color: #2DC78F;
  background: linear-gradient(135deg, #e8f5f0 0%, #f0faf8 100%);
  color: #2DC78F;
  box-shadow: 0 4px 12px rgba(45, 199, 143, 0.15);
}

/* 强度按钮 */
.intensity-buttons {
  display: flex;
  gap: 12px;
}

.intensity-btn {
  flex: 1;
  padding: 14px 8px;
  border: 2px solid #e0e0e0;
  border-radius: 10px;
  font-size: 12px;
  color: #333;
  background-color: #ffffff;
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80px;
}

.intensity-emoji {
  font-size: 24px;
  margin-bottom: 4px;
}

.intensity-text {
  line-height: 1.4;
  font-weight: 600;
}

.intensity-btn.active {
  border-color: #2DC78F;
  background: linear-gradient(135deg, #e8f5f0 0%, #f0faf8 100%);
  color: #2DC78F;
  box-shadow: 0 4px 12px rgba(45, 199, 143, 0.15);
}

/* 营养按钮 */
.nutrition-buttons {
  display: flex;
  gap: 12px;
}

.nutrition-btn {
  flex: 1;
  padding: 14px 8px;
  border: 2px solid #e0e0e0;
  border-radius: 10px;
  font-size: 13px;
  color: #333;
  background-color: #ffffff;
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80px;
  font-weight: 600;
}

.nutrition-emoji {
  font-size: 24px;
  margin-bottom: 4px;
  display: block;
}

.nutrition-btn.active {
  border-color: #2DC78F;
  background: linear-gradient(135deg, #e8f5f0 0%, #f0faf8 100%);
  color: #2DC78F;
  box-shadow: 0 4px 12px rgba(45, 199, 143, 0.15);
}

/* 自定义营养 */
.custom-nutrition {
  background: linear-gradient(135deg, #f9fffe 0%, #f0faf8 100%);
  border-radius: 10px;
  padding: 14px;
  margin-bottom: 16px;
  border-left: 4px solid #2DC78F;
}

/* 结果显示 */
.result-display {
  background: linear-gradient(135deg, #e8f5f0 0%, #f0faf8 100%);
  border-radius: 10px;
  padding: 18px;
  margin-top: 12px;
  border-left: 4px solid #2DC78F;
  box-shadow: 0 4px 12px rgba(45, 199, 143, 0.1);
}

.result-label {
  font-size: 12px;
  color: #999;
  margin-bottom: 8px;
  font-weight: 600;
}

.result-value {
  font-size: 28px;
  font-weight: 700;
  color: #2DC78F;
}

.result-unit {
  font-size: 14px;
  color: #999;
  margin-left: 4px;
  font-weight: 400;
}

/* 结果占位符 */
.result-placeholder {
  background: linear-gradient(135deg, #f9f9f9 0%, #f5f5f5 100%);
  border-radius: 10px;
  padding: 24px;
  text-align: center;
  margin-top: 12px;
  border: 2px dashed #e0e0e0;
}

.placeholder-text {
  font-size: 13px;
  color: #999;
}

/* 高亮卡片 */
.highlight-card {
  background: linear-gradient(135deg, #2DC78F 0%, #25a870 100%);
  text-align: center;
  padding: 28px 18px;
  box-shadow: 0 8px 24px rgba(45, 199, 143, 0.25);
}

.highlight-label {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 8px;
  font-weight: 600;
}

.highlight-value {
  font-size: 40px;
  font-weight: 700;
  color: #ffffff;
}

.highlight-unit {
  font-size: 16px;
  color: rgba(255, 255, 255, 0.85);
  margin-left: 4px;
  font-weight: 400;
}

/* 营养结果 */
.nutrition-results {
  margin-top: 12px;
  padding-top: 12px;
  border-top: 2px solid #f0f0f0;
}

.nutrition-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 0;
  border-bottom: 1px solid #f9f9f9;
}

.nutrition-item:last-child {
  border-bottom: none;
}

.nutrition-label {
  display: flex;
  align-items: center;
  font-size: 13px;
  color: #666;
  font-weight: 600;
}

.nutrition-emoji {
  font-size: 18px;
  margin-right: 8px;
  display: inline-block;
}

.nutrition-value {
  font-size: 13px;
  color: #2DC78F;
  font-weight: 700;
  text-align: right;
}

/* 第4天部分 */
.day4-section {
  margin-top: 16px;
  padding-top: 16px;
  border-top: 2px dashed #2DC78F;
}

.day4-title {
  font-size: 13px;
  color: #2DC78F;
  font-weight: 700;
  margin-bottom: 12px;
  padding: 8px 12px;
  background-color: rgba(45, 199, 143, 0.08);
  border-radius: 6px;
}

/* 百分比控制 */
.percent-control {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: 10px;
}

.percent-btn {
  width: 44px;
  height: 44px;
  border: 2px solid #2DC78F;
  border-radius: 10px;
  font-size: 20px;
  color: #2DC78F;
  background-color: #ffffff;
  font-weight: 700;
  transition: all 0.3s ease;
}

.percent-btn:active {
  background-color: #e8f5f0;
  transform: scale(0.95);
}

.percent-display {
  flex: 1;
  text-align: center;
  font-size: 20px;
  font-weight: 700;
  color: #2DC78F;
  background: linear-gradient(135deg, #e8f5f0 0%, #f0faf8 100%);
  padding: 12px;
  border-radius: 10px;
  border: 2px solid #2DC78F;
}

.percent-hint {
  font-size: 12px;
  color: #999;
  margin-top: 8px;
  text-align: center;
}

/* 结果项 */
.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 0;
  border-bottom: 1px solid #f0f0f0;
}

.result-item:last-child {
  border-bottom: none;
}

.result-item .result-label {
  font-size: 13px;
  color: #666;
  margin: 0;
  font-weight: 600;
}

.result-item .result-value {
  font-size: 16px;
  color: #2DC78F;
  font-weight: 700;
  margin: 0;
}

/* 保存按钮 */
.save-btn {
  width: 100%;
  padding: 14px;
  background: linear-gradient(135deg, #2DC78F 0%, #25a870 100%);
  color: #ffffff;
  border-radius: 10px;
  font-size: 15px;
  font-weight: 700;
  margin-top: 18px;
  border: none;
  box-shadow: 0 4px 12px rgba(45, 199, 143, 0.25);
  transition: all 0.3s ease;
}

.save-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2px 6px rgba(45, 199, 143, 0.15);
}

/* 数据项 */
.data-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 0;
  border-bottom: 1px solid #f0f0f0;
}

.data-item:last-child {
  border-bottom: none;
}

.data-label {
  font-size: 13px;
  color: #666;
  font-weight: 600;
}

.data-value {
  font-size: 14px;
  color: #2DC78F;
  font-weight: 700;
}

/* BMI显示 */
.bmi-display {
  background: linear-gradient(135deg, #e8f5f0 0%, #f0faf8 100%);
  border-radius: 10px;
  padding: 28px;
  text-align: center;
  margin-bottom: 16px;
  border: 2px solid rgba(45, 199, 143, 0.2);
}

.bmi-value {
  font-size: 40px;
  font-weight: 700;
  color: #2DC78F;
}

.bmi-status {
  font-size: 15px;
  color: #2DC78F;
  margin-top: 8px;
  font-weight: 700;
}

/* BMI刻度 */
.bmi-scale {
  display: flex;
  justify-content: space-around;
  margin-bottom: 16px;
  padding: 14px 0;
  border-top: 2px solid #f0f0f0;
  border-bottom: 2px solid #f0f0f0;
}

.scale-item {
  text-align: center;
}

.scale-label {
  font-size: 12px;
  color: #666;
  font-weight: 600;
}

.scale-range {
  font-size: 11px;
  color: #999;
  margin-top: 4px;
}

/* 7日体重记录 */
.weight-records {
  margin-top: 16px;
  padding: 14px;
  background-color: #f8f9fa;
  border-radius: 10px;
  border-left: 4px solid #2DC78F;
}

.records-title {
  font-size: 14px;
  font-weight: 700;
  color: #333;
  margin-bottom: 12px;
}

.records-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  max-height: 200px;
  overflow-y: auto;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 12px;
  background-color: #ffffff;
  border-radius: 6px;
  border: 1px solid #e8e8e8;
}

.record-date {
  font-size: 12px;
  color: #999;
  flex: 1;
}

.record-weight {
  font-size: 13px;
  font-weight: 700;
  color: #2DC78F;
}

.weight-records-empty {
  margin-top: 16px;
  padding: 20px;
  text-align: center;
  background-color: #f8f9fa;
  border-radius: 10px;
}

.empty-text {
  font-size: 13px;
  color: #999;
}

/* 记录按钮 */
.record-btn {
  width: 100%;
  padding: 14px;
  background: linear-gradient(135deg, #2DC78F 0%, #25a870 100%);
  color: #ffffff;
  border-radius: 10px;
  font-size: 15px;
  font-weight: 700;
  margin-top: 18px;
  border: none;
  box-shadow: 0 4px 12px rgba(45, 199, 143, 0.25);
  transition: all 0.3s ease;
}

.record-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2px 6px rgba(45, 199, 143, 0.15);
}

/* FAQ项 */
.faq-item {
  padding: 14px 0;
  border-bottom: 1px solid #f0f0f0;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-question {
  font-size: 13px;
  color: #333;
  font-weight: 700;
  margin-bottom: 8px;
}

.faq-answer {
  font-size: 12px;
  color: #999;
  line-height: 1.6;
}

/* ==================== 减脂与增肌小知识 ==================== */
.knowledge-card {
  background-color: #ffffff;
}

.knowledge-content {
  background: linear-gradient(135deg, #e8f5f0 0%, #f0faf8 100%);
  border-radius: 10px;
  padding: 16px;
  border-left: 4px solid #2DC78F;
}

.knowledge-text {
  font-size: 14px;
  color: #333;
  line-height: 1.8;
  font-weight: 500;
}

/* ==================== 记录打卡 - 日历 ==================== */
.calendar-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14px;
}

.calendar-nav-btn {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  color: #2DC78F;
  background-color: #f0faf8;
  border-radius: 8px;
  font-weight: 700;
}

.calendar-nav-btn:active {
  background-color: #e0f5ee;
}

.calendar-nav-title {
  font-size: 16px;
  font-weight: 700;
  color: #333;
}

.calendar-weekdays {
  display: flex;
  margin-bottom: 8px;
}

.calendar-weekday {
  flex: 1;
  text-align: center;
  font-size: 12px;
  color: #999;
  font-weight: 600;
  padding: 6px 0;
}

.calendar-days {
  display: flex;
  flex-wrap: wrap;
}

.calendar-day {
  width: 14.2857%;
  text-align: center;
  padding: 6px 0;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 44px;
}

.day-number {
  font-size: 14px;
  color: #333;
  font-weight: 500;
  width: 32px;
  height: 32px;
  line-height: 32px;
  border-radius: 50%;
  text-align: center;
}

.calendar-day.other-month .day-number {
  color: #d0d0d0;
}

.calendar-day.today .day-number {
  background-color: #2DC78F;
  color: #ffffff;
  font-weight: 700;
}

.calendar-day.checked-in .day-number {
  background-color: #e8f5f0;
  color: #2DC78F;
  font-weight: 700;
}

.calendar-day.today.checked-in .day-number {
  background-color: #2DC78F;
  color: #ffffff;
}

.day-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background-color: #2DC78F;
  margin-top: 2px;
}

.calendar-day.today .day-dot {
  background-color: #ffffff;
}

/* ==================== 打卡弹窗 ==================== */
.checkin-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkin-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.checkin-dialog {
  position: relative;
  width: 85%;
  max-height: 80vh;
  background-color: #ffffff;
  border-radius: 16px;
  padding: 20px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
  overflow-y: auto;
}

.checkin-dialog-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18px;
  padding-bottom: 14px;
  border-bottom: 2px solid #f0f0f0;
}

.checkin-dialog-title {
  font-size: 16px;
  font-weight: 700;
  color: #333;
}

.checkin-dialog-close {
  font-size: 18px;
  color: #999;
  padding: 4px 8px;
}

.checkin-form {
  margin-bottom: 16px;
}

.checkin-input-group {
  margin-bottom: 16px;
}

.checkin-input-label {
  font-size: 13px;
  color: #666;
  font-weight: 600;
  margin-bottom: 8px;
  display: block;
}

.checkin-input-field {
  width: 100%;
  padding: 12px 14px;
  border: 2px solid #e0e0e0;
  border-radius: 10px;
  font-size: 15px;
  color: #333;
  background-color: #ffffff;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.checkin-input-field:focus {
  border-color: #2DC78F;
  box-shadow: 0 0 0 3px rgba(45, 199, 143, 0.1);
  outline: none;
}

.checkin-textarea {
  width: 100%;
  min-height: 100px;
  padding: 12px 14px;
  border: 2px solid #e0e0e0;
  border-radius: 10px;
  font-size: 14px;
  color: #333;
  background-color: #ffffff;
  box-sizing: border-box;
  line-height: 1.6;
  transition: all 0.3s ease;
}

.checkin-textarea:focus {
  border-color: #2DC78F;
  box-shadow: 0 0 0 3px rgba(45, 199, 143, 0.1);
  outline: none;
}

.checkin-save-btn {
  width: 100%;
  padding: 14px;
  background: linear-gradient(135deg, #2DC78F 0%, #25a870 100%);
  color: #ffffff;
  border-radius: 10px;
  font-size: 15px;
  font-weight: 700;
  border: none;
  box-shadow: 0 4px 12px rgba(45, 199, 143, 0.25);
  transition: all 0.3s ease;
}

.checkin-save-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2px 6px rgba(45, 199, 143, 0.15);
}
