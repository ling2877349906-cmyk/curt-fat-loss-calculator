<view class="container page-content">
  <!-- 个人信息卡片 -->
  <view class="card">
    <view class="card-title">个人信息</view>
    
    <!-- 每日总热量 -->
    <view class="info-bar">
      <view class="info-content">
        <view class="info-title">每日总热量建议</view>
        <view class="info-value">{{tdee}}<text class="value-unit">千卡</text></view>
      </view>
      <button class="info-button" bindtap="onRecalculate">重新计算</button>
    </view>

    <!-- 身体数据 -->
    <view style="margin-top: 16px; padding-top: 16px; border-top: 1px solid #f0f0f0;">
      <view class="input-label">身体数据</view>
      <view class="data-compare">
        <view class="compare-item">
          <view class="compare-value">{{age}}</view>
          <view class="compare-label">岁</view>
        </view>
        <view class="compare-item">
          <view class="compare-value">{{weight}}</view>
          <view class="compare-label">公斤</view>
        </view>
        <view class="compare-item">
          <view class="compare-value">{{height}}</view>
          <view class="compare-label">厘米</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 营养素分配 -->
  <view class="card">
    <view class="card-title">每日营养素分配建议</view>
    
    <!-- 碳水 -->
    <view class="nutrition-item">
      <view class="nutrition-header">
        <view class="nutrition-name">碳水</view>
        <view>
          <view class="nutrition-grams">{{nutrition.carbs.grams}}<text class="nutrition-grams-unit">克</text></view>
          <view class="nutrition-calories">{{nutrition.carbs.calories}}千卡</view>
        </view>
      </view>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{nutrition.carbs.percent}}%; background-color: #FF6B6B;"></view>
      </view>
    </view>

    <!-- 蛋白质 -->
    <view class="nutrition-item">
      <view class="nutrition-header">
        <view class="nutrition-name">蛋白质</view>
        <view>
          <view class="nutrition-grams">{{nutrition.protein.grams}}<text class="nutrition-grams-unit">克</text></view>
          <view class="nutrition-calories">{{nutrition.protein.calories}}千卡</view>
        </view>
      </view>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{nutrition.protein.percent}}%; background-color: #9B59B6;"></view>
      </view>
    </view>

    <!-- 脂肪 -->
    <view class="nutrition-item">
      <view class="nutrition-header">
        <view class="nutrition-name">脂肪</view>
        <view>
          <view class="nutrition-grams">{{nutrition.fat.grams}}<text class="nutrition-grams-unit">克</text></view>
          <view class="nutrition-calories">{{nutrition.fat.calories}}千卡</view>
        </view>
      </view>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{nutrition.fat.percent}}%; background-color: #F39C12;"></view>
      </view>
    </view>
  </view>

  <!-- 体重变化 -->
  <view class="card">
    <view class="card-title">体重变化</view>
    
    <view class="data-compare">
      <view class="compare-item">
        <view class="compare-value">{{targetWeight}}</view>
        <view class="compare-label">目标体重</view>
        <view class="compare-underline" style="background-color: #FF9800;"></view>
      </view>
      <view class="compare-item">
        <view class="compare-value">{{weight}}</view>
        <view class="compare-label">当前体重</view>
        <view class="compare-underline" style="background-color: #2DC78F;"></view>
      </view>
    </view>

    <!-- 进度显示 -->
    <view style="margin-top: 16px; padding-top: 16px; border-top: 1px solid #f0f0f0;">
      <view class="input-label">减重进度</view>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{progressPercent}}%; background-color: #2DC78F;"></view>
      </view>
      <view style="font-size: 12px; color: #999; text-align: center; margin-top: 8px;">
        已减重 {{weight - targetWeight}} 公斤 / 共需减重 {{initialWeight - targetWeight}} 公斤
      </view>
    </view>

    <button class="btn btn-primary" bindtap="onRecordWeight" style="margin-top: 16px;">记录体重</button>
  </view>

  <!-- BMI指数 -->
  <view class="card">
    <view class="card-title">身体质量指数</view>
    
    <view style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
      <view>
        <view style="font-size: 12px; color: #999; margin-bottom: 4px;">BMI 指数</view>
        <view style="font-size: 24px; font-weight: 700; color: #333;">{{bmi}}</view>
      </view>
      <view style="text-align: right;">
        <view style="font-size: 14px; font-weight: 600; color: #2DC78F;">{{bmiStatus}}</view>
      </view>
    </view>

    <!-- BMI进度条 -->
    <view class="progress-bar" style="height: 8px;">
      <view class="progress-fill" style="width: {{bmiPercent}}%; background-color: #FF6B6B;"></view>
    </view>

    <!-- BMI范围标签 -->
    <view style="display: flex; justify-content: space-between; margin-top: 8px; font-size: 11px; color: #999;">
      <view>偏瘦</view>
      <view>正常</view>
      <view>偏胖</view>
      <view>肥胖</view>
    </view>

    <!-- BMI说明 -->
    <view style="margin-top: 16px; padding-top: 16px; border-top: 1px solid #f0f0f0; font-size: 12px; color: #666; line-height: 1.8;">
      <view>BMI = 体重(kg) ÷ 身高(m)²</view>
      <view style="margin-top: 8px; color: #999;">
        <view>• 偏瘦: BMI &lt; 18.5</view>
        <view>• 正常: 18.5 ≤ BMI &lt; 24</view>
        <view>• 偏胖: 24 ≤ BMI &lt; 28</view>
        <view>• 肥胖: BMI ≥ 28</view>
      </view>
    </view>
  </view>

  <!-- 猜你想问 -->
  <view class="card">
    <view class="card-title">猜你想问</view>
    
    <view wx:for="{{qaList}}" wx:key="id" class="qa-item">
      <view class="qa-question" bindtap="toggleQA" data-id="{{item.id}}">
        <view>{{item.question}}</view>
        <view class="qa-icon">{{item.expanded ? '−' : '+'}}</view>
      </view>
      <view class="qa-answer {{item.expanded ? 'show' : ''}}">{{item.answer}}</view>
    </view>
  </view>

  <!-- 底部空间 -->
  <view style="height: 20px;"></view>
</view>
