.page-container {
  background: linear-gradient(135deg, #F0F8FF 0%, #E8F4FF 100%);
  min-height: 100vh;
  padding-bottom: 20px;
}

/* 页面标题 */
.page-header {
  text-align: center;
  padding: 24px 16px 16px;
}

.header-emoji {
  font-size: 48px;
  display: block;
  margin-bottom: 8px;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10px);
  }
}

.header-title {
  font-size: 24px;
  font-weight: 700;
  color: #000000;
  margin-bottom: 4px;
}

.header-subtitle {
  font-size: 13px;
  color: #999;
}

/* 卡片 */
.card {
  background-color: #f7f8fa;
  margin: 12px;
  border-radius: 16px;
  padding: 18px;
  box-shadow: 0 4px 12px rgba(255, 107, 157, 0.08);
  border: 1px solid rgba(255, 107, 157, 0.1);
}

.card-title {
  display: flex;
  align-items: center;
  font-size: 16px;
  font-weight: 700;
  color: #333;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 2px solid #f0f0f0;
  background-color: #f0f8ff;
  padding: 10px 12px;
  margin: -16px -16px 16px -16px;
  border-radius: 12px 12px 0 0;
}

.title-emoji {
  font-size: 20px;
  margin-right: 8px;
  display: inline-block;
}

/* 体重摘要 */
.weight-summary {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 12px 0;
}

.weight-summary-item {
  text-align: center;
  flex: 1;
}

.weight-summary-label {
  font-size: 13px;
  color: #999;
  font-weight: 600;
  margin-bottom: 8px;
}

.weight-summary-value {
  font-size: 24px;
  font-weight: 700;
  color: #000000;
}

.weight-summary-divider {
  width: 1px;
  height: 50px;
  background-color: #f7f8fa;
  margin: 0 16px;
}

/* 体重记录列表 */
.weight-records {
  margin-top: 4px;
}

.records-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  max-height: 280px;
  overflow-y: auto;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 12px;
  background-color: #f7f8fa;
  border-radius: 8px;
  border: 1px solid #e8e8e8;
}

.record-date {
  font-size: 12px;
  color: #999;
  flex: 1;
}

.record-weight {
  font-size: 14px;
  font-weight: 700;
  color: #000000;
}

.weight-records-empty {
  padding: 24px;
  text-align: center;
}

.empty-text {
  font-size: 13px;
  color: #999;
}

/* 折线图 */
.chart-container {
  width: 100%;
  height: 220px;
  margin-top: 4px;
}

.weight-chart {
  width: 100%;
  height: 220px;
}

/* 输入组 */
.input-group {
  margin-bottom: 14px;
}

.input-label {
  font-size: 13px;
  color: #666;
  margin-bottom: 10px;
  display: block;
  font-weight: 600;
}

.input-field {
  width: 100%;
  height: 48px;
  padding: 0 14px;
  border: 2px solid #e0e0e0;
  border-radius: 10px;
  font-size: 16px;
  color: #333333 !important;
  background-color: #ffffff !important;
  box-sizing: border-box;
  transition: all 0.3s ease;
  display: block;
  position: relative;
  z-index: 1;
}

.placeholder-style {
  color: #cccccc !important;
  font-size: 16px;
}

.input-field:focus {
  border-color: #000000;
  box-shadow: 0 0 0 3px rgba(255, 107, 157, 0.1);
  outline: none;
}

/* 记录按钮 */
.record-btn {
  width: 100%;
  padding: 14px;
  background: linear-gradient(135deg, #99ccff 0%, #99ccff 100%);
  color: #ffffff;
  border-radius: 10px;
  font-size: 15px;
  font-weight: 700;
  margin-top: 12px;
  border: none;
  box-shadow: 0 4px 12px rgba(255, 107, 157, 0.25);
  transition: all 0.3s ease;
}

.record-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2px 6px rgba(255, 107, 157, 0.15);
}
